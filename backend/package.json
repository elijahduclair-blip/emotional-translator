{
    "version":  "1.0.0",
    "dependencies":  {
                         "dotenv":  "^16.3.1",
                         "pg":  "^8.11.3",
                         "express":  "^4.18.2",
                         "cors":  "^2.8.5"
                     },
    "name":  "emotional-color-translator-api",
    "type":  "module",
    "description":  "Backend API for Emotional Color Translator",
    "scripts":  {
                    "migrate":  "node src/db/migrate.js",
                    "seed":  "node src/db/seed.js",
                    "dev":  "node --watch src/server.js",
                    "start":  "node src/server.js",
                    "deploy:start":  "npm run migrate && npm run seed && npm start",
                    "backup":  "node src/db/backup.js backup",
                    "backup:list":  "node src/db/backup.js list",
                    "backup:restore":  "node src/db/backup.js restore"
                    ,"test":  "node --test --test-concurrency=1"
                },
    "devDependencies":  {
                            "nodemon":  "^3.0.2"
                        },
    "main":  "src/server.js"
}
